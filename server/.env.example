# NOX server environment example
# Copy this file to ".env" in the same folder and fill in the values you have.

# Required for Telegram Mini App login
NOX_TELEGRAM_BOT_TOKEN=
NOX_TELEGRAM_LAUNCH_URL=

# Optional: support relay to Telegram admin chat
# Use the target group/chat id here. You can provide multiple ids separated by commas.
NOX_TELEGRAM_CHAT_ID=

# Recommended before public launch
NOX_CLIENT_BIND=http://127.0.0.1:3001
NOX_SERVER_CHAT_PASSWORD=change-me-before-launch

# Optional overrides
# NOX_SERVER_PORT=15003
# NOX_SERVER_BIND=0.0.0.0
# NOX_SERVER_NAME=NOX Arena
# NOX_SERVER_STATS_PORT=88
